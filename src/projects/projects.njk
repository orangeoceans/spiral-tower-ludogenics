---
layout: base.njk
title: Games
permalink: /projects/
---
<h1>Games</h1>

{% set released = [] %}
{% set indev = [] %}
{% set jams = [] %}
{% for project in collections.projects %}
  {% if project.data.status == "Released" %}
    {% set released = (released.push(project), released) %}
  {% elif project.data.status == "Game Jam" %}
    {% set jams = (jams.push(project), jams) %}
  {% else %}
    {% set indev = (indev.push(project), indev) %}
  {% endif %}
{% endfor %}

{% if released.length %}
<section class="games-section">
  <h2>Released</h2>
  <div class="project-grid">
    {% for project in released %}
      {% include "project-card.njk" %}
    {% endfor %}
  </div>
</section>
{% endif %}

{% if indev.length %}
<section class="games-section">
  <h2>In Development</h2>
  <div class="project-grid">
    {% for project in indev %}
      {% include "project-card.njk" %}
    {% endfor %}
  </div>
</section>
{% endif %}

{% if jams.length %}
<section class="games-section">
  <h2>Game Jams</h2>
  <div class="project-grid">
    {% for project in jams %}
      {% include "project-card.njk" %}
    {% endfor %}
  </div>
</section>
{% endif %}
