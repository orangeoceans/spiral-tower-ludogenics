---
layout: base.njk
---
<article class="post">
  <header class="post-header">
    <h1>{{ title }}</h1>
    {% if description %}
    <p class="post-description">{{ description }}</p>
    {% endif %}
    {% if author or tags %}
    <div class="post-meta-row">
      <span class="post-meta">
        {% if author %}by {{ author }} · {% endif %}
        <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
      </span>
      {% if tags %}
      <div class="tags">
        {% for tag in tags %}
          {% if tag != "essays" %}
          <span class="tag">{{ tag }}</span>
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
    </div>
    {% else %}
    <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
    {% endif %}
  </header>
  <div class="post-body">
    {{ content | safe }}
  </div>
</article>
